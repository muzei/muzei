    <string name="about_title">O <xliff:g id="muzei_name">Muzei</xliff:g></string>
    <string name="about_body"><![CDATA[Vytvořili Roman Nurik a Ian Lake, se zásadním přispěním
        <a href="http://code.muzei.co">open source komunity</a>.
        <i>Muzei</i> je přepis ruského slova
        <a href="http://translate.google.com/#en/ru/museum"><i>музей</i></a>, které znamená
        &#8220;muzeum.&#8221;<br><br>

        Copyright 2013&ndash;2018 Google Inc. Všechna práva vyhrazena.
        <a href="http://m.google.com/utos">Podmínky služby</a>,
        <a href="http://www.google.com/policies/privacy/">Ochrana soukromí</a>&nbsp;<br><br>

        Mnohokrát děkujeme:<br>
        &bull; <b><a href="http://square.github.io/okhttp/">OkHttp</a> a <a href="http://square.github.io/picasso/">Picasso</a></b> od Square<br>
        &bull; <b><a href="https://github.com/GLWallpaperService/GLWallpaperService">GLWallpaperService</a></b> od Robert Green, Mark F. Guerra a dalších
    ]]></string>
