    <string name="about_title">Acerca de <xliff:g id="muzei_name">Muzei</xliff:g></string>
    <string name="about_body"><![CDATA[        Feito por Roman Nurik e Ian Lake, com grandes contribuições da
        <a href="http://code.muzei.co">comunidade de código aberto</a>.
        <i>Muzei</i> é uma transliteração da palavra russa
        <a href="http://translate.google.com/#en/ru/museum"><i>музей</i></a>, que significa
        &#8220;museu.&#8221;<br><br>

        Copyright 2013&ndash;2018 Google Inc. All Rights Reserved.
        <a href="http://m.google.com/utos">Terms of Service</a>,
        <a href="http://www.google.com/policies/privacy/">Privacy Policy</a>&nbsp;<br><br>

        Agradecimentos aos seguintes projetos de código aberto:<br>
        &bull; <b><a href="http://square.github.io/okhttp/">OkHttp</a> and <a href="http://square.github.io/picasso/">Picasso</a></b> by Square<br>
        &bull; <b><a href="https://github.com/GLWallpaperService/GLWallpaperService">GLWallpaperService</a></b> de Robert Green, Mark F. Guerra, e outros
    ]]></string>
