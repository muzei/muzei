    <string name="about_title">À propos de <xliff:g id="muzei_name">Muzei</xliff:g></string>
    <string name="about_body"><![CDATA[        Fait par Roman Nurik et Ian Lake, avec des contributions majeures de
        la <a href="http://code.muzei.co">communauté open source</a>.
        <i>Muzei</i> est une transcription du mot russe
        <a href="https://translate.google.com/#fr/ru/musée"><i>музей</i></a> signifiant
        &#8220;musée.&#8221;<br><br>

        Copyright 2013&ndash;2018 Google Inc. Tous droits réservés.
        <a href="http://m.google.com/utos">Conditions d’utilisation</a>,
        <a href="http://www.google.com/policies/privacy/">Politique de confidentialité</a>&nbsp;<br><br>

        Nous remercions infiniment ces projets open source :<br>
        &bull; <b><a href="http://square.github.io/okhttp/">OkHttp</a> et <a href="http://square.github.io/picasso/">Picasso</a></b> par Square<br>
        &bull; <b><a href="https://github.com/GLWallpaperService/GLWallpaperService">GLWallpaperService</a></b> par Robert Green, Mark F. Guerra, et d’autres
    ]]></string>
